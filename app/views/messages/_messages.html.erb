<%# Loop over messages and display each one %>
<% messages.each do |message| %>

  <% if message.role == "user" %>
    <%# User message — aligned to the RIGHT %>
    <div class="chloe-msg-row user">
      <div class="chloe-msg-sender" style="justify-content: flex-end;">
        You
      </div>
      <div class="chloe-bubble chloe-bubble-user">
        <%= simple_format(ERB::Util.html_escape(message.content)) %>
      </div>
    </div>

  <% elsif message.role == "assistant" %>
    <%# Chloé's message — aligned to the LEFT %>
    <div class="chloe-msg-row">
      <div class="chloe-msg-sender">
        Chloé 2.0
      </div>
      <div class="chloe-bubble chloe-bubble-chloe">
        <%= simple_format(ERB::Util.html_escape(message.content)) %>
      </div>
    </div>

  <% end %>

<% end %>
