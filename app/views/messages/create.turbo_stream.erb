<%# Update the chat title if it was just generated %>
<% if @chat.title_previously_changed? %>
  <%= turbo_stream.update "chat_title", @chat.title %>
<% end %>

<%# Reset the input form after sending a message %>
<%= turbo_stream.update "new_message_container" do %>
  <%= render "messages/form", job: @job, chat: @chat, message: Message.new %>
<% end %>
