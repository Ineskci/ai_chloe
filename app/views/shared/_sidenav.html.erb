<ul class="position-sticky sticky-top nav flex-column">
  <li class="nav-item">
    <%= link_to "#", class: "nav-link text-dark", data: { action: "click->toggle#call" } do %>
      <i class="fa-regular fa-square-caret-left"></i>
    <% end %>
  </li>
  <% @jobs.each do |job| %>
    <li class="nav-item">
      <%= link_to job.job_title, job_path(job), class: "nav-link text-dark" %>
    </li>
  <% end %>
</ul>
