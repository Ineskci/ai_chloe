<% content_for :no_layout, true %>

<!-- NAV -->
<nav class="chloe-nav">
  <a href="/" class="chloe-nav-logo">
    Chloé
    <span class="chloe-logo-pill">2.0</span>
  </a>
  <div class="chloe-nav-center">
    <a href="#how">How it works</a>
    <a href="#roles">Roles</a>
    <a href="#stories">Stories</a>
  </div>
  <div class="chloe-nav-right">
    <%= link_to "Log in", new_user_session_path, class: "chloe-btn-login" %>
    <%= link_to "Start for free →", new_user_registration_path, class: "chloe-btn-signup" %>
  </div>
</nav>

<!-- HERO -->
<section class="chloe-hero">
  <div class="chloe-hero-blob"></div>

  <div class="chloe-hero-inner">
    <div class="chloe-hero-left">
      <div class="chloe-sticker">
        <span class="chloe-sticker-dot"></span>
        Le Wagon SP · Batch #2203
      </div>

      <h1 class="chloe-hero-title">
        The AI that<br>
        preps you for<br>
        <span class="chloe-underline-limon">your dream job.</span>
      </h1>

      <p class="chloe-hero-sub">
        Chloé 2.0 simulates real interviews, gives you honest feedback, and turns bootcamp grads into <strong>confident candidates</strong> — before the real thing.
      </p>

      <div class="chloe-hero-actions">
        <%= link_to new_user_registration_path, class: "chloe-btn-cta" do %>
          Practice with Chloé <span class="chloe-arrow">→</span>
        <% end %>
        <a href="#how" class="chloe-btn-watch">
          <div class="chloe-watch-icon">▶</div>
          See how it works
        </a>
      </div>

      <div class="chloe-social-proof">
        <div class="chloe-avatars">
          <div class="chloe-avatar" style="background:#7C5CF6;">AP</div>
          <div class="chloe-avatar" style="background:#F4703A;">KM</div>
          <div class="chloe-avatar" style="background:#22A56F;">SL</div>
          <div class="chloe-avatar" style="background:#3B82F6;">JR</div>
          <div class="chloe-avatar" style="background:#E63F5A;">TN</div>
        </div>
        <div class="chloe-social-text">
          Joined by <strong>40+ Wagon students</strong> this batch
        </div>
      </div>
    </div>

    <!-- Chat Card -->
    <div class="chloe-chat-wrap">
      <div class="chloe-sticky-note chloe-sticky-1">💡 Junior Dev track</div>
      <div class="chloe-sticky-note chloe-sticky-2">Score: 8.5 / 10 🎯</div>
      <div class="chloe-card">
        <div class="chloe-card-topbar">
          <div class="chloe-topbar-dots">
            <div class="chloe-tdot chloe-tdot-r"></div>
            <div class="chloe-tdot chloe-tdot-y"></div>
            <div class="chloe-tdot chloe-tdot-g"></div>
          </div>
          <div class="chloe-topbar-title">chloe_2.0 — interview_session</div>
          <div class="chloe-topbar-live"><span></span>live</div>
        </div>
        <div class="chloe-card-header">
          <div class="chloe-avatar-c">C</div>
          <div>
            <div class="chloe-card-name">Chloé 2.0</div>
            <div class="chloe-card-sub">your_interview_coach.rb</div>
          </div>
          <div class="chloe-track-chip">junior dev</div>
        </div>
        <div class="chloe-card-messages">
          <div class="chloe-msg">
            <div class="chloe-msg-who">Chloé</div>
            <div class="chloe-bubble chloe-bubble-chloe">Tell me about a time you had to debug something really tricky.</div>
          </div>
          <div class="chloe-msg">
            <div class="chloe-msg-who chloe-right">You</div>
            <div class="chloe-bubble chloe-bubble-user">I had an N+1 query in Rails — found it with the Bullet gem...</div>
          </div>
          <div class="chloe-msg">
            <div class="chloe-msg-who">Chloé</div>
            <div class="chloe-bubble chloe-bubble-feedback">
              ✦ Great STAR structure! One push — how did you <em>verify</em> the fix worked?
            </div>
          </div>
          <div class="chloe-typing-row"><span></span><span></span><span></span></div>
        </div>
        <div class="chloe-card-input">
          <span class="chloe-card-input-text">I checked with the Rails logs and then…</span>
          <div class="chloe-send-btn">→</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="chloe-section chloe-how" id="how">
  <div class="chloe-section-eyebrow"><span class="chloe-eyebrow-line"></span> how it works</div>
  <h2 class="chloe-section-title">Three sessions.<br><em>Real confidence.</em></h2>
  <div class="chloe-how-grid">
    <div class="chloe-how-card">
      <div class="chloe-how-num">01</div>
      <div class="chloe-how-icon">🎯</div>
      <div class="chloe-how-title">Pick your track</div>
      <div class="chloe-how-desc">Choose your target role — Junior Dev, PM, UX, or Data Analyst. Chloé tailors every question to your exact path.</div>
    </div>
    <div class="chloe-how-card">
      <div class="chloe-how-num">02</div>
      <div class="chloe-how-icon">💬</div>
      <div class="chloe-how-title">Do the interview</div>
      <div class="chloe-how-desc">Answer like in a real interview. Chloé follows up and won't let you get away with vague answers.</div>
    </div>
    <div class="chloe-how-card">
      <div class="chloe-how-num">03</div>
      <div class="chloe-how-icon">📈</div>
      <div class="chloe-how-title">Get your feedback</div>
      <div class="chloe-how-desc">Instant, honest, actionable. Chloé scores your answers and shows you exactly how to improve.</div>
    </div>
  </div>
</section>

<!-- ROLES -->
<section class="chloe-section" id="roles">
  <div class="chloe-section-eyebrow"><span class="chloe-eyebrow-line"></span> career tracks</div>
  <h2 class="chloe-section-title">Four paths.<br><em>One coach.</em></h2>
  <div class="chloe-roles-grid">
    <% [
      { emoji: "💻", name: "Junior Developer", code: "junior_dev", desc: "Rails & Ruby deep-dives, live coding, culture fit prep.", tags: ["Ruby on Rails", "JavaScript", "SQL", "Git"] },
      { emoji: "🗂️", name: "Product Manager", code: "product_manager", desc: "Prioritization frameworks and stakeholder scenarios.", tags: ["Strategy", "User stories", "Metrics"] },
      { emoji: "🎨", name: "UX Designer", code: "ux_designer", desc: "Walk through your design process and portfolio.", tags: ["Design process", "Figma", "Research"] },
      { emoji: "📊", name: "Data Analyst", code: "data_analyst", desc: "SQL challenges and data storytelling.", tags: ["SQL", "Python", "Business cases"] }
    ].each do |role| %>
      <div class="chloe-role-card">
        <div class="chloe-role-top">
          <div class="chloe-role-emoji-wrap"><%= role[:emoji] %></div>
          <div>
            <div class="chloe-role-name"><%= role[:name] %></div>
            <div class="chloe-role-code">track: "<%= role[:code] %>"</div>
          </div>
        </div>
        <div class="chloe-role-desc"><%= role[:desc] %></div>
        <div class="chloe-role-tags">
          <% role[:tags].each do |tag| %>
            <span class="chloe-rtag"><%= tag %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>

<!-- TESTIMONIALS -->
<section class="chloe-section chloe-testi-section" id="stories">
  <div class="chloe-section-eyebrow"><span class="chloe-eyebrow-line" style="background:rgba(255,255,255,0.35);"></span> student stories</div>
  <h2 class="chloe-section-title" style="color:white;">They practiced.<br><em>They got hired.</em></h2>
  <div class="chloe-testi-grid">
    <% [
      { quote: "I did 3 sessions the night before my interview. The feedback was so precise — I got the offer the next day.", name: "Ana M.", batch: "batch_2187 · Junior Dev", initials: "AM", color: "linear-gradient(135deg,#7C5CF6,#A78BFA)" },
      { quote: "As a career changer, I had no idea how to talk about my past in tech. Chloé taught me to reframe everything.", name: "Karim L.", batch: "batch_2194 · Product Manager", initials: "KL", color: "linear-gradient(135deg,#F4703A,#FBBF24)" },
      { quote: "The follow-up questions make it real. It doesn't let you be vague — exactly like an actual interviewer.", name: "Sofia P.", batch: "batch_2201 · UX Designer", initials: "SP", color: "linear-gradient(135deg,#22A56F,#38BDF8)" }
    ].each do |t| %>
      <div class="chloe-testi-card">
        <div class="chloe-testi-stars">★★★★★</div>
        <p class="chloe-testi-quote">"<%= t[:quote] %>"</p>
        <div class="chloe-testi-author">
          <div class="chloe-testi-av" style="background:<%= t[:color] %>;"><%= t[:initials] %></div>
          <div>
            <div class="chloe-testi-name"><%= t[:name] %></div>
            <div class="chloe-testi-batch"><%= t[:batch] %></div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</section>

<!-- CTA -->
<section class="chloe-cta-section">
  <div class="chloe-cta-inner">
    <div class="chloe-cta-badge">✦ Free for Le Wagon students</div>
    <h2 class="chloe-cta-title">Ready to nail<br>
