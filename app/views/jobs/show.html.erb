<div class="row">
  <div class="col">
    <h1><%= @job.job_title %></h1>
  </div>

  <div class="col-md-3">
    <h2>Chats</h2>

    <div class="mb-4">
      <% if @chats.any? %>
        <ul>
          <% @chats.each do |chat| %>
            <li><%= link_to chat.title, job_chat_path(@job, chat) %></li>
          <% end %>
        </ul>
      <% else %>
        <p>There are no chats yet.</p>
      <% end %>
    </div>

<div class="row">
  <div class="col">
    <h1><%= @job.job_title %></h1>
  </div>
  <div class="col-md-3">
    <h2>Chats</h2>
    <!-- ... -->

 <%= link_to "New chat", new_job_chat_path(@job), class: "btn btn-primary" %>
  </div>
</div>
